<html>
<head>
    <meta charset="UTF-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <title>Panel de Optimizaci&oacute;n</title>
    <HTA:APPLICATION
        ID="OptimizerPanel"
        APPLICATIONNAME="Panel de Optimizacion"
        BORDER="thin"
        BORDERSTYLE="normal"
        CAPTION="yes"
        MAXIMIZEBUTTON="no"
        MINIMIZEBUTTON="yes"
        SHOWINTASKBAR="yes"
        SINGLEINSTANCE="yes"
        SYSMENU="yes"
        WINDOWSTATE="normal"
        SCROLL="auto"
    />
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            font-family: 'Inter', 'Segoe UI', Tahoma, sans-serif;
            background: #030a12;
            color: #f4f4f5;
            padding: 24px;
            width: 520px;
        }
        h1 { text-align:center; font-size:26px; font-weight:900; margin-bottom:4px; letter-spacing:0.5px; background:linear-gradient(135deg, #fff 0%, #AEE2F9 40%, #55CDF5 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .subtitle { text-align:center; color:rgba(255, 255, 255, 0.55); margin-bottom:20px; font-size:13px; font-weight:300; }
        .rambar-wrap { background:rgba(4, 100, 172, 0.04); border:1px solid rgba(85, 205, 245, 0.15); border-radius:12px; padding:12px 16px; margin-bottom:20px; }
        .rambar-label { font-size:13px; color:rgba(255,255,255,0.7); margin-bottom:10px; display:flex; justify-content:space-between; align-items:center; }
        .refresh-btn { background:transparent; border:1px solid rgba(85,205,245,0.3); padding:4px 10px; border-radius:8px; color:#55CDF5; cursor:pointer; font-size:12px; transition:all 0.2s; }
        .refresh-btn:hover { background:#55CDF5; color:#000; }
        .rambar-track { background:#000; border-radius:6px; height:8px; overflow:hidden; border:1px solid rgba(255,255,255,0.05); }
        .rambar-fill { height:100%; border-radius:6px; background:linear-gradient(90deg,#0464AC,#55CDF5); transition:width 0.3s ease; }
        .section { color:#55CDF5; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:2px; margin:20px 0 10px 4px; }
        .btn { display:block; width:100%; padding:16px 20px; margin:10px 0; border:1px solid rgba(85,205,245,0.1); border-radius:12px; font-size:14px; font-weight:700; cursor:pointer; text-align:left; color:#fff; transition:all 0.2s ease; background:rgba(4, 100, 172, 0.05); position:relative; overflow:hidden; }
        .btn:hover { border-color:rgba(85,205,245,0.4); transform:translateY(-2px); }
        .btn-streaming { border-left:4px solid #8b5cf6; }
        .btn-gaming    { border-left:4px solid #06b6d4; }
        .btn-restore   { border-left:4px solid #e94560; }
        .btn-clean     { border-left:4px solid #f59e0b; }
        .btn-update    { border-left:4px solid #3b82f6; }
        .btn-power     { border-left:4px solid #10b981; }
        .btn-dns       { border-left:4px solid #0464AC; }
        .btn-web       { border-left:4px solid #55CDF5; background:linear-gradient(135deg,rgba(4,100,172,0.1),transparent); margin-top:20px; }
        .desc { font-size:12px; font-weight:400; color:rgba(255,255,255,0.55); margin-top:6px; line-height:1.5; }
        .row { display:flex; gap:12px; margin:10px 0; }
        .row .btn { margin:0; flex:1; font-size:13px; padding:14px 16px; min-height:80px; }
        .status { margin-top:20px; padding:16px 20px; border-radius:12px; background:rgba(4,100,172,0.04); border:1px solid rgba(85,205,245,0.15); border-left:4px solid #0464AC; font-size:13px; min-height:70px; line-height:1.6; color:#f4f4f5; }
        .status-label { color:#55CDF5; font-weight:bold; margin-bottom:6px; font-size:11px; text-transform:uppercase; letter-spacing:1px; }
    </style>

    <script language="VBScript">

        Dim WshShell, FSO
        Set WshShell = CreateObject("WScript.Shell")
        Set FSO = CreateObject("Scripting.FileSystemObject")
        Dim highPerfActive : highPerfActive = False

        Sub RunPS(code)
            WshShell.Run "powershell -NoProfile -ExecutionPolicy Bypass -Command " & Chr(34) & code & Chr(34), 0, True
        End Sub

        Sub SetStatus(msg)
            document.getElementById("statusText").innerHTML = msg
        End Sub

        Sub RefreshRAM()
            Dim wmi, col, obj, total, free, usedPct
            Set wmi = GetObject("winmgmts:\\.\root\cimv2")
            Set col = wmi.ExecQuery("SELECT TotalVisibleMemorySize,FreePhysicalMemory FROM Win32_OperatingSystem")
            For Each obj In col
                total = CDbl(obj.TotalVisibleMemorySize)
                free  = CDbl(obj.FreePhysicalMemory)
            Next
            Dim usedGB, totalGB, freeGB
            totalGB = FormatNumber(total/1048576, 1)
            freeGB  = FormatNumber(free/1048576, 1)
            usedGB  = FormatNumber((total-free)/1048576, 1)
            usedPct = CInt(((total-free)/total)*100)
            document.getElementById("ramText").innerHTML = "RAM libre: <b>" & freeGB & " GB</b> &nbsp;|&nbsp; Usada: " & usedGB & " / " & totalGB & " GB"
            document.getElementById("ramFill").style.width = usedPct & "%"
            If usedPct > 80 Then
                document.getElementById("ramFill").style.background = "linear-gradient(90deg,#e74c3c,#c0392b)"
            ElseIf usedPct > 60 Then
                document.getElementById("ramFill").style.background = "linear-gradient(90deg,#e67e22,#d35400)"
            Else
                document.getElementById("ramFill").style.background = "linear-gradient(90deg,#06d6a0,#1b9aaa)"
            End If
        End Sub

        Sub OptimizeStreaming()
            SetStatus "Optimizando para STREAMING..."
            RunPS "$p=@('Dropbox','setup','UpdateDriver','LogiAiPromptBuilder','CCleaner','SearchApp','RemoteMouse','msedgewebview2','OneDrive','Spotify','Discord','Steam','EpicGamesLauncher','warp');foreach($n in $p){Stop-Process -Name $n -Force -EA SilentlyContinue};Stop-Service 'CCleaner_service' -Force -EA SilentlyContinue;[GC]::Collect()"
            RefreshRAM
            SetStatus "Streaming listo -- Cerrado: Dropbox, Discord, Steam, Warp, OneDrive, Spotify<br>Arranca OBS y Twitch."
        End Sub

        Sub OptimizeGaming()
            SetStatus "Optimizando para GAMING..."
            RunPS "$p=@('Dropbox','setup','UpdateDriver','LogiAiPromptBuilder','CCleaner','SearchApp','RemoteMouse','msedgewebview2','OneDrive','Spotify','warp','chrome','firefox','msedge');foreach($n in $p){Stop-Process -Name $n -Force -EA SilentlyContinue};Stop-Service 'CCleaner_service' -Force -EA SilentlyContinue;Stop-Service 'SysMain' -Force -EA SilentlyContinue;$gp='HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile\Tasks\Games';Set-ItemProperty $gp 'GPU Priority' 8 -EA SilentlyContinue;Set-ItemProperty $gp 'Priority' 6 -EA SilentlyContinue;[GC]::Collect()"
            RefreshRAM
            SetStatus "Gaming listo -- Cerrado: Chrome, Warp, Dropbox, OneDrive<br>Prioridad GPU aumentada. Lanza tu juego."
        End Sub

        Sub Restore()
            SetStatus "Restaurando servicios..."
            RunPS "Start-Service 'SysMain' -EA SilentlyContinue"
            If highPerfActive Then
                RunPS "powercfg /setactive SCHEME_BALANCED"
                highPerfActive = False
                document.getElementById("powerLabel").innerHTML = "Perfil actual: Equilibrado"
            End If
            RefreshRAM
            SetStatus "Restaurado -- SysMain reactivado, perfil de energia Equilibrado."
        End Sub

        Sub CleanTemp()
            SetStatus "Limpiando archivos temporales y papelera..."
            RunPS "$dirs=@($env:TEMP,'C:\Windows\Temp');foreach($d in $dirs){Get-ChildItem $d -Recurse -Force -EA SilentlyContinue|Remove-Item -Recurse -Force -EA SilentlyContinue};Clear-RecycleBin -Force -EA SilentlyContinue;[GC]::Collect()"
            RefreshRAM
            SetStatus "Limpieza completada -- %TEMP%, C:\Windows\Temp y papelera vaciados."
        End Sub

        Sub FlushDNS()
            SetStatus "Limpiando cache DNS..."
            RunPS "ipconfig /flushdns | Out-Null; netsh winsock reset catalog | Out-Null"
            SetStatus "DNS limpiado -- Cache DNS y Winsock reiniciados. Util contra lag de conexion."
        End Sub

        Sub TogglePower()
            If highPerfActive Then
                RunPS "powercfg /setactive SCHEME_BALANCED"
                highPerfActive = False
                document.getElementById("powerLabel").innerHTML = "Perfil actual: Equilibrado"
                SetStatus "Perfil cambiado a Equilibrado."
            Else
                RunPS "powercfg /setactive SCHEME_MIN"
                highPerfActive = True
                document.getElementById("powerLabel").innerHTML = "Perfil actual: ALTO RENDIMIENTO"
                SetStatus "Perfil cambiado a Alto Rendimiento -- Ideal para gaming y streaming."
            End If
        End Sub

        Sub UpdateApps()
            SetStatus "Comprobando disponibilidad de winget..."
            Dim tmpPath, f, content
            tmpPath = WshShell.ExpandEnvironmentStrings("%TEMP%\winget_check.txt")
            WshShell.Run "cmd /c winget --version > """ & tmpPath & """ 2>&1", 0, True
            
            Dim hasWinget : hasWinget = False
            If FSO.FileExists(tmpPath) Then
                Set f = FSO.OpenTextFile(tmpPath, 1)
                If Not f.AtEndOfStream Then
                    content = f.ReadAll
                    If InStr(content, "v1") > 0 Or InStr(content, "v0") > 0 Or InStr(content, "Windows") > 0 Then hasWinget = True
                End If
                f.Close
                FSO.DeleteFile tmpPath
            End If
            
            If hasWinget Then
                WshShell.Run "cmd /c start """" cmd /c ""title ApliArteZenDash - Actualizaciones & echo === Actualizando Apps === & echo. & winget upgrade --all --silent --accept-source-agreements --accept-package-agreements & echo. & echo Proceso completado. & pause""", 1, False
                SetStatus "Actualizaciones ejecutándose en una nueva ventana..."
            Else
                SetStatus "<span style='color:#ef4444'>Error: winget no detectado. Instala App Installer en la Microsoft Store.</span>"
            End If
        End Sub

        Sub OpenWeb()
            SetStatus "Abriendo ApliArte.com..."
            WshShell.Run "https://apliarte.com", 0, False
        End Sub

        Sub OpenWeb()
            SetStatus "Abriendo ApliArte.com..."
            WshShell.Run "https://apliarte.com", 0, False
        End Sub

        Sub Window_OnLoad()
            RefreshRAM
        End Sub

    </script>
</head>
<body>
    <h1>ApliArte ZenDash</h1>
    <p class="subtitle">El panel definitivo de optimizaci&oacute;n para Windows</p>

    <div class="rambar-wrap">
        <div class="rambar-label">
            <span id="ramText">Calculando RAM...</span>
            <span class="refresh-btn" onclick="RefreshRAM()">&#8635; Actualizar</span>
        </div>
        <div class="rambar-track">
            <div class="rambar-fill" id="ramFill" style="width:0%"></div>
        </div>
    </div>

    <div class="section">Optimizar</div>

    <button class="btn btn-streaming" onclick="OptimizeStreaming()">
        Optimizar para STREAMING
        <div class="desc">Cierra Dropbox, Discord, Steam, Warp, OneDrive, Spotify. Listo para OBS + Twitch.</div>
    </button>

    <button class="btn btn-gaming" onclick="OptimizeGaming()">
        Optimizar para GAMING
        <div class="desc">Cierra Chrome y navegadores. Sube prioridad GPU. Desactiva SysMain.</div>
    </button>

    <button class="btn btn-restore" onclick="Restore()">
        Restaurar servicios
        <div class="desc">Reactiva SysMain y vuelve al perfil de energ&iacute;a Equilibrado.</div>
    </button>

    <div class="section">Herramientas</div>

    <div class="row">
        <button class="btn btn-clean" onclick="CleanTemp()">
            Limpiar temporales
            <div class="desc">Vac&iacute;a %TEMP% y papelera.</div>
        </button>
        <button class="btn btn-dns" onclick="FlushDNS()">
            Flush DNS
            <div class="desc">Limpia cach&eacute; DNS y Winsock.</div>
        </button>
    </div>

    <button class="btn btn-power" onclick="TogglePower()">
        Alternar perfil de energ&iacute;a
        <div id="powerLabel" class="desc">Perfil actual: Equilibrado</div>
    </button>

    <button class="btn btn-update" onclick="UpdateApps()">
        Actualizar aplicaciones (winget)
        <div class="desc">Actualiza Windows, Chrome, OBS, Discord y dem&aacute;s apps instaladas.</div>
    </button>

    <div class="section">Acerca de</div>
    <button class="btn btn-web" onclick="OpenWeb()">
        &#127760; Visitar ApliArte.com
        <div class="desc">Descubre m&aacute;s herramientas, arte y proyectos en mi web oficial.</div>
    </button>
    <div class="status">
        <div class="status-label">Estado</div>
        <div id="statusText">Listo. Selecciona una opci&oacute;n.</div>
    </div>
</body>
</html>
